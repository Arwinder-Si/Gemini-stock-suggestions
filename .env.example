# DhanHQ API Credentials
DHAN_CLIENT_ID="1000000000"
DHAN_ACCESS_TOKEN="your_access_token_here"

# Trading Configuration
# Symbol-to-SecurityID mapping — format: "NAME:ID,NAME:ID"
# Example: RELIANCE is 11536, TCS is 3456 on NSE_EQ
# You can also use plain IDs: "11536,3456"
SYMBOL_SECURITY_IDS="RELIANCE:11536"

# ORB Strategy Settings
ORB_START_TIME="09:15"
ORB_END_TIME="09:30"
MIN_VOLUME_THRESHOLD=10000
RISK_REWARD_RATIO=1.0
TIME_BASED_EXIT="15:15"

# Telegram Notification Settings
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# Webex Notification Settings
WEBEX_TOKEN="your_webex_bot_token"
WEBEX_ROOM_ID="your_webex_room_id"
