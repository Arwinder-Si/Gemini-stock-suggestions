# Dhan API credentials
DHAN_CLIENT_ID=
DHAN_PIN=
DHAN_TOTP_SECRET=

# Comma-separated "NAME:SECURITY_ID" pairs, e.g. RELIANCE:11536,TCS:3456
SYMBOL_SECURITY_IDS=

# Webex bot (outbound alerts + ChatOps listener)
WEBEX_TOKEN=
WEBEX_ROOM_ID=

# Required for interactive ChatOps commands (/ping, /pnl, /plan, /morning).
# Must be a public, internet-reachable URL pointing at webex_listener.py.
# Use HTTPS when possible (ngrok works for testing: ngrok http 5050).
BOT_PUBLIC_URL=
BOT_PORT=5050
